<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Preencher_Data_Entrega_Tampo_Combinada</fullName>
    <active>true</active>
    <errorConditionFormula>AND
(
ISPICKVAL(   Tampo_de_Pedra__c , &apos;SIM&apos;),

ISBLANK(  Entrega_do_Tampo_Combinada_c_Cliente__c  )

)</errorConditionFormula>
