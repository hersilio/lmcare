<apex:page StandardController="Order" extensions="LM_OrderCustomController" renderAs="pdf" showHeader="false" applyHtmlTag="false" standardStylesheets="false">
    <head>
        <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
        <style>
            @page {
          size:A4;
          margin:8mm;
        }
    
        body {
            font-family:Arial;
        }

        h1{
            font-size:22pt;
            margin-top:5px;
        }
        
        h2{
            margin-bottom:5px;
            padding-bottom:0;
        }

        .infoTable {
            width: 100%;
            border-collapse: collapse;
        }

        .infoTable tr, .infoTable 
        td {
            border: 1px solid black;
            padding:5px;
        }

        li {
            padding-bottom: 8px;
            font-size: 11pt;
        }
        
        .accInfo p{
            padding:0;
            margin:0;
            font-size:11pt;
        }
        
      .dataTable{
          border-collapse: collapse;
          border: 2px solid black;
      }
        
      .dataTableHeader{
          border: 2px solid black;
          font-size:10pt;
          text-align: center;
      }
      
      .dataTableFooter{
          font-size: 10pt;
          text-align: center;
          background-color: #DDDDDD;
          border:2px solid black;
      }
      
      .artigos{
          text-align:center;
          padding-left:10px;
          font-size:10pt;
          border-left:2px solid black;
          border-right:2px solid black;
      }
        </style>

</head>

<body>

    <header>
        <apex:image url="{!$Resource.LM_PdfTemplateHeader}" width="100%"/>
    </header>
    <main>
<p style='margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;'><strong><span style='font-size:20px;line-height:115%;font-family:"Leroy Merlin Sans";'>CD: {!Order.OrderNumber} &nbsp; LOJA: {!Order.Store_Name__c}</span></strong></p>
    <p style='margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;text-align:center;background:white;'><strong><span style='font-size:11px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>DADOS CLIENTE</span></strong></p>
    <table style="width: 5.3e+2pt;border-collapse:collapse;border:none;">
        <tbody>
            <tr>
                <td style="width: 177.75pt;border: 1pt solid black;padding: 5pt;vertical-align: top;">
                    <p style='margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;background:white;border:none;'><strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>NOME</span></strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>: {!Order.Account_Name__c}</span></p>
                    <p style='margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;background:white;border:none;'><strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>TELEFONE</span></strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>: {!Order.Account.Phone}</span></p>
                </td>
                <td style="width: 353.25pt;border-top: 1pt solid black;border-right: 1pt solid black;border-bottom: 1pt solid black;border-image: initial;border-left: none;padding: 5pt;vertical-align: top;">
                    <p style='margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;background:white;'><strong><span style='font-size:12px;line-height:115%;font-family:  "Leroy Merlin Sans";color:black;background:white;'>MORADA DE ENTREGA / RECOLHA</span></strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>:&nbsp;</span></p>
                    <p style='margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;background:white;'><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>{!Order.ShippingStreet} {!Order.ShippingPostalCode} {!Order.ShippingCity}&nbsp;</span></p>
                </td>
            </tr>
        </tbody>
    </table>
    <p style='font-weight:bold;margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;text-align:center;'><span style='font-size:11px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;'>DADOS DO CERTIFICADO</span></p>
    <table style="width: 5.3e+2pt;border-collapse:collapse;border:2px solid black;">
        <tbody>
            <tr>
                <td style="width: 265.65pt;border: 1pt solid black;padding: 5pt;height: 56.75pt;vertical-align: top;">
                    <p style='margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;background:white;border:none;'><strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>SOLICITADO POR :</span></strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>&nbsp;{!Order.Nome_do_Vendedor__c}</span></p>
                    <p style='margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;background:white;border:none;'><strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>SOLICITADO DIA :</span></strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>
                    <apex:outputText value="{0, date, dd/MM/yyyy}">
                        <apex:Param value="{!Order.EffectiveDate }" />
                    </apex:OutputText></span></p>
                    
                    <p style='margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;background:white;'><strong><span style='font-size:12px;line-height:115%;font-family:  "Leroy Merlin Sans";color:black;background:white;'>TRANSPORTE A SER REALIZADO POR :</span></strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>&nbsp;</span></p>
                    <p style='margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;background:white;'><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>
                    <apex:outputField value="{!Order.Tipo_de_Transportador__c}"></apex:outputField>
                    </span></p>
                    
                </td>
                <td style="width: 265.65pt;border-top: 1pt solid black;border-right: 1pt solid black;border-bottom: 1pt solid black;border-image: initial;border-left: none;padding: 5pt;height: 56.75pt;vertical-align: top;">
                    <p style='margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;background:white;border:none;'><strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>DATA DE RECOLHA&nbsp;</span></strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>: 
                    <apex:outputText value="{0, date, dd/MM/yyyy}">
                        <apex:Param value="{!Order.Data_de_Devolucao__c}" />
                    </apex:OutputText>
                    </span></p>
                    <p style='margin:0cm;line-height:115%;font-size:15px;font-family:"Arial",sans-serif;background:white;border:none;'><strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>PEDIDO A RECOLHER: </span></strong><span style='font-size:12px;line-height:115%;font-family:"Leroy Merlin Sans";color:black;background:white;'>{!Order.N_mero_do_Pedido_a_Recolher__c}</span></p>
