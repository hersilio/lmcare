                </td>
            </tr>
        </tbody>
    </table>
    <br/>
    <apex:dataTable style="fontsize:9pt; border-collapse: collapse;" styleClass="dataTable" headerClass="dataTableHeader" footerClass="dataTableFooter" rowClasses="artigos" value="{!artigosRecolha}" var="artigoRecolha" width="100%">
                <apex:column styleclass="artigos" style="width:15%">
                    <apex:facet name="header">MATERIAL A RECOLHER LM</apex:facet>
                    <apex:outputText value="{!artigoRecolha.Name}"/>
                </apex:column>
                <apex:column styleclass="artigos" style="width:30%">
                    <apex:facet name="header">DESCRIÇÃO</apex:facet>
                    <apex:outputText value="{!artigoRecolha.Designacao__c}"/>
                </apex:column>
                <apex:column styleclass="artigos" style="width:12%;">
                    <apex:facet name="header">UNIDADES</apex:facet>
                    <apex:outputText value="{!artigoRecolha.Quantidade__c}"/>
                </apex:column>
                <apex:column styleclass="artigos" style="width:12%;">
                    <apex:facet name="header">PESO(Unit.)</apex:facet>
                    <apex:outputText value="{!artigoRecolha.Peso_Unitario__c}"/>
                </apex:column>
                <apex:column styleclass="artigos" style="width:12%;">
                        <apex:facet name="header">PESO (Total)</apex:facet>
                    <apex:outputText value="{!artigoRecolha.Peso_Total__c}"/>
                    <apex:facet name="footer"> 
                        <apex:outputText value="{0, number, ###,##0.00}" >
                            <apex:param value="{!Order.Peso_Total_Recolha__c}"/>
                        </apex:outputText>
                    </apex:facet>
                </apex:column>
                <apex:column styleclass="artigos" style="width:9%;">
                    <apex:facet name="header">PVP</apex:facet>
                    <apex:outputText value="{!artigoRecolha.PVP__c} €"/>
                    
                    <apex:facet name="footer">TOTAL:</apex:facet>
                </apex:column>
                <apex:column styleclass="artigos" style="width:9%;">
                    <apex:facet name="header">VALOR</apex:facet>
                    <apex:outputText value="{!artigoRecolha.Valor__c} €"/>
                    <apex:facet name="footer"> 
                        <apex:outputText value="{0, number, ###,##0.00 €}">
                            <apex:param value="{!Order.Valor_Total_de_Recolha__c}"/>
                        </apex:outputText>
                    </apex:facet>
                </apex:column>
                
            </apex:dataTable>
            <br/> 
            
            <apex:dataTable rendered="{!Order.Tipo_CD__c = 'Troca'}" styleClass="dataTable" headerClass="dataTableHeader" footerClass="dataTableFooter" rowClasses="artigos" value="{!artigosEntrega}" var="artigoEntrega" width="100%">
