<apex:page standardController="ServiceAppointment">
    <apex:includeScript value="//code.jquery.com/jquery-3.6.0.min.js"/>
    <apex:includeScript value="//cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"/>
    <apex:stylesheet value="//cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"/>
    <style>
        .modal-header {
            display: flex;
            justify-content: center;
            position: relative;
        }
        .modal-title {
            margin: 0 auto;
        }
        .btn-close {
            position: absolute;
            right: 15px;
        }
        .modal-body {
            font-size: 14px; /* Increase the font size here */
        }
    </style>
    <script>
        $(document).ready(function(){
            $('#myModal').modal('show');
        });
    </script>

    <!-- Modal -->
    <div class="modal fade" id="myModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header text-center">
            <h5 class="modal-title" id="exampleModalLabel">Ação Indisponível</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" onclick="window.history.back();" aria-label="Close"></button>
          </div>
          <div class="modal-body text-center">
            Esta ação não pode ser realizada a partir deste botão. 
            <p>Por favor, utilize as opções disponíveis dentro da marcação selecionada.</p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="window.history.back();">Fechar</button>
          </div>
        </div>
      </div>
    </div>

</apex:page>